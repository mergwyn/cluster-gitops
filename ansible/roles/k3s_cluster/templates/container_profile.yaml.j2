name: k3s-container
description: Profile for k3s LXC containers
config:
  boot.autostart: "true"
  limits.cpu: "{{ cpus }}"
  limits.memory: "{{ memory }}"
  linux.kernel_modules: "ip_tables,ip6_tables,netlink_diag,nf_nat,overlay,br_netfilter,xt_conntrack,xt_comment,xt_mark,xt_addrtype,xt_multiport,xt_statistic,xt_tcpudp"
  raw.lxc: |-
    lxc.apparmor.profile = unconfined
    lxc.cap.drop = 
    lxc.cgroup2.devices.allow = a
    lxc.cgroup2.devices.allow = c 10:200 rwm
    lxc.mount.auto = proc:rw sys:rw
    lxc.mount.entry = /proc/sys/fs/binfmt_misc var/lib/lxc/proc/sys/fs/binfmt_misc none bind,optional 0 0
  security.nesting: "true"
  security.privileged: "true"
  security.syscalls.intercept.mknod: "true"
  security.syscalls.intercept.setxattr: "true"
devices:
  aadisable:
    path: /sys/module/apparmor/parameters/enabled
    source: /dev/null
    type: disk
  root:
    path: /
    pool: {{ storage_pool | default('local') }}
    type: disk
  eth0:
    name: eth0
    nictype: bridged
    parent: {{ network_bridge | default('br0') }}
    type: nic
  kmsg:
    path: /dev/kmsg
    type: unix-char
