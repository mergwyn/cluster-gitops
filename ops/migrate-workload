#!/usr/bin/env bash
# migrate-workload.sh

# Usage: ./migrate-workload.sh <target-node> <namespace> <app-name> [-d]
TARGET_NODE=$1
TARGET_NS=$2
APP_NAME=$3
DRY_RUN=false

scale_operator() {
    local replicas=$1
    local action=$([ "$replicas" -eq 0 ] && echo "down" || echo "up")

    # Find any prometheus-operator deployment in the namespace
    # Uses the stable component label rather than instance, which varies
    OPERATOR_DEPLOYMENT=$(kubectl get deployment -n "$TARGET_NS" \
        -l "app.kubernetes.io/component=prometheus-operator" \
        -o name 2>/dev/null | head -1)

    if [[ -z "$OPERATOR_DEPLOYMENT" ]]; then
        return 0  # No operator in this namespace, nothing to do
    fi

    # Only act if our target is a StatefulSet managed by the operator
    # i.e. it's a Prometheus or Alertmanager CR
    if kubectl get prometheus,alertmanager -n "$TARGET_NS" 2>/dev/null | \
        grep -qE "(prometheus|alertmanager)-${APP_NAME}|${APP_NAME}"; then

        echo "--- Scaling $action Prometheus Operator ($OPERATOR_DEPLOYMENT) ---"
        kubectl scale "$OPERATOR_DEPLOYMENT" -n "$TARGET_NS" --replicas="$replicas"

        if [ "$replicas" -eq 0 ]; then
            kubectl wait --for=delete pod \
                -l "app.kubernetes.io/component=prometheus-operator" \
                -n "$TARGET_NS" --timeout=60s
        else
            kubectl rollout status "$OPERATOR_DEPLOYMENT" \
                -n "$TARGET_NS" --timeout=60s
        fi
    fi
}

# Check for dry-run flag anywhere in args
for arg in "$@"; do
    if [[ "$arg" == "-d" || "$arg" == "--dry-run" ]]; then
        DRY_RUN=true
    fi
done

# Prompt if arguments are missing
if [[ -z "$TARGET_NODE" ]]; then echo "Enter Target Node (e.g., 'charlie'):"; read -r TARGET_NODE; fi
if [[ -z "$TARGET_NS" ]]; then echo "Enter Namespace (e.g., 'media'):"; read -r TARGET_NS; fi
if [[ -z "$APP_NAME" ]]; then echo "Enter App Name (e.g., 'tautulli'):"; read -r APP_NAME; fi

if [ "$DRY_RUN" = true ]; then
    echo "!!! DRY RUN MODE ENABLED - No changes will be made !!!"
fi

# The selector used by most Helm/Argo apps
SELECTOR="app.kubernetes.io/instance=$APP_NAME"

echo "--- 1. Verification: Identifying Resources & Source Node ---"

# Dynamically find the SOURCE_NODE by looking at where the current pods are running
SOURCE_NODE=$(kubectl get pods -n "$TARGET_NS" -l "$SELECTOR" -o jsonpath='{.items[0].spec.nodeName}')

if [[ -z "$SOURCE_NODE" ]]; then
    echo "Error: Could not find any running pods for '$APP_NAME' to determine source node."
    exit 1
fi

if [[ "$SOURCE_NODE" == "$TARGET_NODE" ]]; then
    echo "Error: App is already running on $TARGET_NODE. Nothing to migrate."
    exit 1
fi

DEPLOYS=$(kubectl get deployment -l "$SELECTOR" -n "$TARGET_NS" -o name)
STATEFULSETS=$(kubectl get statefulset -l "$SELECTOR" -n "$TARGET_NS" -o name)
PVCS=$(kubectl get pvc -l "$SELECTOR" -n "$TARGET_NS" -o name)

echo "Migration Plan:"
echo "  From: $SOURCE_NODE  -->  To: $TARGET_NODE"
echo "  Resources: $DEPLOYS $STATEFULSETS"
echo "  PVCs: $PVCS"

if [ "$DRY_RUN" = true ]; then
    echo "--- DRY RUN COMPLETE ---"
    exit 0
fi

BACKUP_NAME="migration-$APP_NAME-$(date +%Y%m%d-%H%M%S)"

# --- REAL WORK STARTS HERE ---

echo "--- 2. Configuring Velero Node Mapping ($SOURCE_NODE -> $TARGET_NODE) ---"
cat <<EOF | kubectl apply -f -
apiVersion: v1
kind: ConfigMap
metadata:
  name: change-pvc-node-selector-config
  namespace: velero
  labels:
    velero.io/plugin-config: ""
    velero.io/change-pvc-node-selector: RestoreItemAction
data:
  ${SOURCE_NODE}: ${TARGET_NODE}
EOF

echo "--- Identifying Workload Type ---"
# Check for Deployment
if kubectl get deployment -l "$SELECTOR" -n "$TARGET_NS" 2>&1 | grep -q "No resources found"; then
    WORKLOAD_KIND=""
else
    WORKLOAD_KIND="deployment"
fi

# If no deployment, check for StatefulSet
if [[ -z "$WORKLOAD_KIND" ]]; then
    if ! kubectl get statefulset -l "$SELECTOR" -n "$TARGET_NS" 2>&1 | grep -q "No resources found"; then
        WORKLOAD_KIND="statefulset"
    fi
fi

if [[ -z "$WORKLOAD_KIND" ]]; then
    echo "Error: No Deployment or StatefulSet found for $APP_NAME"
    exit 1
fi

echo "Detected Workload: $WORKLOAD_KIND"

echo "--- 3. Scaling Down $APP_NAME ---"
scale_operator 0
kubectl scale "$WORKLOAD_KIND" -l "$SELECTOR" --replicas=0 -n "$TARGET_NS"
kubectl wait --for=delete pod -l "$SELECTOR" -n "$TARGET_NS" --timeout=60s

echo "--- 4. Velero Backup ---"
velero backup create "$BACKUP_NAME" \
  --include-namespaces "$TARGET_NS" \
  --selector "$SELECTOR" \
  --wait

echo "--- 5. Deleting PVCs and released PVs on $SOURCE_NODE ---"
# Capture the PV names before deleting the PVCs
PV_NAMES=$(kubectl get pvc -l "$SELECTOR" -n "$TARGET_NS" \
    -o jsonpath='{.items[*].spec.volumeName}')

kubectl delete pvc -l "$SELECTOR" -n "$TARGET_NS"

# Wait briefly for PVs to transition to Released, then delete them
# so OpenEBS provisions fresh ones on the target node
if [[ -n "$PV_NAMES" ]]; then
    echo "Deleting backing PVs: $PV_NAMES"
    for pv in $PV_NAMES; do
        # Wait for Released status (reclaim policy means it won't auto-delete)
        kubectl wait pv "$pv" --for=jsonpath='{.status.phase}'=Released \
            --timeout=30s 2>/dev/null || true
        kubectl delete pv "$pv"
    done
fi

echo "--- 6. Restoring to $TARGET_NODE ---"
velero restore create "restore-$BACKUP_NAME" \
  --from-backup "$BACKUP_NAME" \
  --existing-resource-policy update

echo "Waiting for PVCs to be created by Velero..."
# Loop until the PVC appears or we timeout (60s)
TIMEOUT=60
COUNTER=0
until kubectl get pvc -n "$TARGET_NS" -l "$SELECTOR" | grep -q "$APP_NAME" || [ $COUNTER -eq $TIMEOUT ]; do
  sleep 2
  ((COUNTER+=2))
done

if [ $COUNTER -eq $TIMEOUT ]; then
  echo "Error: PVC did not appear in time. Check Velero logs."
  exit 1
fi

echo "--- 6.5 Cleaning PVC selectors for OpenEBS compatibility ---"
for pvc in $(kubectl get pvc -n "$TARGET_NS" -l "$SELECTOR" -o name); do
    echo "Patching $pvc..."
    kubectl patch "$pvc" -n "$TARGET_NS" --type json -p='[{"op": "remove", "path": "/spec/selector"}]' || true
done

echo "--- 7. Scaling Up & Waiting ---"
scale_operator 1
kubectl scale "$WORKLOAD_KIND" -l "$SELECTOR" --replicas=1 -n "$TARGET_NS"

echo "Waiting for rollout..."
kubectl rollout status "$WORKLOAD_KIND" -l "$SELECTOR" -n "$TARGET_NS" --timeout=5m

echo "--- FINISHED ---"
