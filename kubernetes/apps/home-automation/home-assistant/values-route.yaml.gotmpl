---
# yaml-language-server: $schema=https://raw.githubusercontent.com/bjw-s-labs/helm-charts/common-5.0.1/charts/library/common/values.schema.json
route:
  app:
    hostnames:
      - &host "hass.{{.Values.cluster.domain}}"
    parentRefs: &parentrefs
      - name: traefik-internal
        namespace: network
        sectionName: websecure
    rules:
      - backendRefs:
          - identifier: app
            port: 8123
  code-server:
    hostnames:
      - "hass-code.{{.Values.cluster.domain}}"
    parentRefs: *parentrefs
    rules:
      - backendRefs:
          - identifier: code-server
            port: 12322

ingress:
  external:
    enabled: true
    className: cloudflare-tunnel
    annotations:
      cloudflare-tunnel-ingress-controller.strrl.dev/backend-protocol: http
    hosts:
      - host: *host
        paths:
          - path: /
            pathType: Prefix
            service:
              identifier: app
              port: http
